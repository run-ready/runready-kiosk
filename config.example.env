# RunReady Operations display kiosk — per-device configuration
# Copy to /etc/runready-kiosk/config.env on the Raspberry Pi and fill in values.
#
# Get a token: sign in at https://ops.runready.app, open DevTools → Application →
# Local Storage → auth_token. Use a dedicated display user per department.
# Tokens last 30 days; the watchdog refreshes them automatically via /auth/verify.

# --- Required ---

# JWT from ops.runready.app localStorage (auth_token)
RUNREADY_AUTH_TOKEN=""

# Page to show after auth: /cad or /calendar (full URL also works)
RUNREADY_DISPLAY_URL="https://ops.runready.app/cad"

# Organization shown in the header (Application → localStorage → selectedOrganizationId)
RUNREADY_ORGANIZATION_ID=""

# --- Optional ---

# For calendar wall displays: hide chrome until mouse moves near top
RUNREADY_CALENDAR_KIOSK_MODE="true"

# Base URLs (change only for local dev)
RUNREADY_OPS_BASE_URL="https://ops.runready.app"
RUNREADY_API_BASE_URL="https://api.runready.app"

# Watchdog intervals (seconds)
RUNREADY_CHECK_DEPLOY_INTERVAL_SEC=300
RUNREADY_TOKEN_REFRESH_INTERVAL_SEC=21600
RUNREADY_BROWSER_HEALTH_INTERVAL_SEC=60

# Hide mouse cursor after 5s idle (requires unclutter)
RUNREADY_HIDE_CURSOR="true"

# Chromium user-data directory (persists localStorage between reboots)
RUNREADY_CHROMIUM_PROFILE_DIR="/var/lib/runready-kiosk/chromium"

# Log directory
RUNREADY_LOG_DIR="/var/log/runready-kiosk"
